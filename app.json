{
  "expo": {
    "name": "PickMe",
    "slug": "PickMe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/pickme_logo.png",
    "scheme": "PickMe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/pickme_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.PickMe"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo/pickme_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash/pickme_splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fc7f20"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
